# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Encrypt the database connection with TLS. Strongly recommended whenever the
# DB is reached over a network (e.g. a separate Coolify service): without it,
# credentials and query data travel in plaintext. Accepts true/1/require/on/yes.
# Certificate verification is ALWAYS on; for a server signed by a private CA,
# paste its PEM into DATABASE_CA_CERT.
# DATABASE_SSL=true
# DATABASE_CA_CERT=

# Token to access the GitHub API (zen quotes, repo cards, last commit)
GITHUB_TOKEN=your_github_token_here

# SMTP configuration for the contact form
MAIL_HOST=your_mail_host_here
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=your_email_here
MAIL_PASS=your_app_password_here

# Address that receives contact notifications (defaults to MAIL_USER)
MAIL_ADMIN_USER=your_admin_email_here

# Admin panel accounts live in the database (no env credentials).
# Create the first account with: npm run admin:create -- <username>

# Number of reverse proxies in front of the app (Coolify/Traefik = 1).
# Controls how X-Forwarded-For is trusted for rate limiting.
TRUST_PROXY_HOPS=1

# Optional: override the listen port (default 8080 in prod, 3000 in dev)
# PORT=8080
