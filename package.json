{
  "name": "portfolio-server",
  "version": "1.0.0",
  "description": "Personal portfolio with static frontend and backend capabilities",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev:api": "nodemon --ignore 'src' --ignore '*.json' server.js",
    "dev:web": "astro dev --port 4321",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "build": "astro build",
    "preview": "astro preview",
    "migrate": "node db/migrate.js"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.48.4",
    "compression": "^1.7.4",
    "dotenv": "^17.2.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.0.1",
    "nodemailer": "^7.0.5",
    "pg": "^8.13.3",
    "sass": "^1.93.2"
  },
  "devDependencies": {
    "astro": "^5.0.0",
    "concurrently": "^9.0.0",
    "nodemon": "^3.1.10"
  }
}
