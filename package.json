{
  "name": "portfolio",
  "version": "2.0.0",
  "description": "Personal portfolio — Astro static frontend served by a hardened Express API",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev:api": "nodemon --watch server server/index.js",
    "dev:web": "astro dev --port 4321",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest run",
    "migrate": "node db/migrate.js"
  },
  "license": "MIT",
  "dependencies": {
    "compression": "^1.8.0",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "helmet": "^8.1.0",
    "nodemailer": "^8.0.10",
    "pg": "^8.16.0"
  },
  "overrides": {
    "shell-quote": "^1.8.4"
  },
  "devDependencies": {
    "astro": "^6.4.5",
    "concurrently": "^9.0.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.0",
    "vitest": "^3.2.0"
  }
}
