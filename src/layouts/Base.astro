---
import '../styles/global.css';
import '../styles/sections.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Sergio González Sánchez - Portfolio',
  description = 'Portfolio of Sergio González Sánchez, developer specialized in C++ and Python. Explore skills, projects and achievements.'
} = Astro.props;

const ogDescription = 'Passionate C++ and Python developer focused on scalable and efficient solutions. Check out my projects and achievements.';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{title}</title>
  <meta name="description" content={description}>

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={ogDescription} />
  <meta property="og:image" content="https://elbiti.com/assets/preview.png" />
  <meta property="og:url" content="https://elbiti.com/" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Sergio González Sánchez Portfolio" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={ogDescription} />
  <meta name="twitter:image" content="https://elbiti.com/assets/preview.png" />

  <link rel="icon" type="image/svg+xml" href="/assets/icon.svg">
  <link rel="apple-touch-icon" href="/assets/apple-icon.png">
  <link rel="canonical" href="https://elbiti.com/">

  <link rel="preload" href="/assets/fonts/Intel_One_Mono/IntelOneMono-VariableFont_wght.ttf" as="font" type="font/ttf" crossorigin>
  <link rel="preload" href="/assets/fonts/Poppins/Poppins-Regular.ttf" as="font" type="font/ttf" crossorigin>

  <!-- Pre-paint theme. External file: page ships zero inline scripts so the
       server's strict CSP (script-src 'self') holds. -->
  <script src="/theme-init.js" is:inline></script>

  <!-- Structured data: JSON-LD is a non-executable data block, CSP-safe -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Sergio González Sánchez',
    url: 'https://elbiti.com',
    image: 'https://elbiti.com/assets/personal-foto.jpg',
    jobTitle: 'Software Developer',
    description: 'Passionate C++ and Python developer focused on scalable and efficient solutions.',
    sameAs: [
      'https://github.com/sgonsan',
      'https://www.linkedin.com/in/sergio-gonsan/'
    ],
    knowsAbout: ['C++', 'Python', 'JavaScript', 'HTML5', 'CSS3', 'Bash', 'Linux']
  })} />
</head>

<body>
  <a class="skip-link" href="#main">skip to content</a>
  <slot />
</body>
</html>
