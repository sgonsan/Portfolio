---
---
<section class="timeline" id="timeline">
  <h2>Timeline</h2>
  <div id="timeline-list" class="timeline-list" aria-live="polite" aria-busy="true">
    <article class="timeline-item loading">
      <div class="timeline-dot"></div>
      <div class="timeline-content">
        <div class="timeline-date skeleton" style="width: 120px;"></div>
        <h3 class="skeleton" style="width: 60%; height: 1.2rem;"></h3>
        <p class="skeleton" style="height: 2.6rem;"></p>
      </div>
    </article>
    <article class="timeline-item loading">
      <div class="timeline-dot"></div>
      <div class="timeline-content">
        <div class="timeline-date skeleton" style="width: 100px;"></div>
        <h3 class="skeleton" style="width: 70%; height: 1.2rem;"></h3>
        <p class="skeleton" style="height: 2.6rem;"></p>
      </div>
    </article>
  </div>
</section>
