---
const links = [
  ['#about', 'about'],
  ['#skills', 'skills'],
  ['#projects', 'projects'],
  ['#timeline', 'timeline'],
  ['#achievements', 'achievements'],
  ['#contact', 'contact']
];
---
<header class="header">
  <a class="logo" href="#about">elbiti</a>
  <nav class="nav" aria-label="Sections">
    {links.map(([href, label]) => <a href={href}>{label}</a>)}
  </nav>
  <button id="theme-toggle" type="button" aria-live="polite">[theme]</button>
</header>
