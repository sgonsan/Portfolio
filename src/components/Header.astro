---
const { sections = [] } = Astro.props;
// nav skips "about" label collision none; labels mirror section keys
---
<header class="header">
  <a class="logo" href="#about">elbiti</a>
  <nav class="nav" aria-label="Sections">
    {sections.map((key) => <a href={`#${key}`}>{key}</a>)}
  </nav>
  <button id="theme-toggle" type="button" aria-live="polite">[theme]</button>
</header>
