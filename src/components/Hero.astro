---
const { c } = Astro.props;
---
<section class="pane hero-pane" id="about" aria-label="About me">
  <div class="pane-bar"><span class="pane-path"><b>sergio@elbiti</b>:{c.path}</span></div>
  <div class="pane-body hero-layout">
    <div class="hero-text">
      <p class="hero-greeting">{c.greeting}</p>
      <h1>{c.name}</h1>
      <p>{c.description}</p>
      <p id="zen-quote" class="zen-quote" aria-live="polite"></p>
    </div>
    <div class="hero-img-frame">
      <img
        src="/assets/personal-foto-low-res.jpg"
        srcset="/assets/personal-foto.jpg 800w, /assets/personal-foto-low-res.jpg 400w"
        sizes="(min-width: 768px) 200px, 132px"
        alt="Foto de perfil de Sergio González Sánchez"
        class="hero-img"
        width="200"
        height="200"
        decoding="async"
      >
    </div>
  </div>
  <p class="scroll-hint" aria-hidden="true">{c.scroll_hint}</p>
</section>
