---
const { c } = Astro.props;
---
<section class="pane" id="skills" aria-label="Skills">
  <div class="pane-bar"><span class="pane-path"><b>sergio@elbiti</b>:{c.path}</span></div>
  <div class="pane-body">
    <h2>{c.title}</h2>
    <div class="skills-groups">
      {c.groups.map((group) => (
        <div class="skill-group">
          <h3>{group.name}</h3>
          <ul>
            {group.items.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
