---
const { c } = Astro.props;
---
<section class="pane" id="achievements" aria-label="Achievements">
  <div class="pane-bar"><span class="pane-path"><b>sergio@elbiti</b>:{c.path}</span></div>
  <div class="pane-body">
    <h2>{c.title}</h2>
    <ul class="achievement-list">
      {c.items.map((a) => (
        <li>
          <h3>{a.title}</h3>
          <p>{a.description}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
