---
---
<div id="project-overlay" class="project-overlay" aria-hidden="true">
  <div class="project-modal" role="dialog" aria-modal="true" aria-labelledby="project-modal-title">
    <button class="project-close" aria-label="Close">[ x ]</button>
    <div class="project-modal-content">
      <h3 id="project-modal-title"></h3>
      <p id="project-modal-desc"></p>
      <div class="project-meta" id="project-modal-meta" hidden>
        <div class="meta-row" id="meta-stars" hidden><span class="meta-label">[stars]</span> <span></span></div>
        <div class="meta-row" id="meta-updated" hidden><span class="meta-label">[updated]</span> <span></span></div>
        <div class="meta-row" id="meta-language" hidden><span class="meta-label">[lang]</span> <span></span></div>
      </div>
      <a id="project-modal-link" href="#" target="_blank" rel="noopener">view repo</a>
    </div>
  </div>
</div>
