---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Skills from '../components/Skills.astro';
import Projects from '../components/Projects.astro';
import Timeline from '../components/Timeline.astro';
import Achievements from '../components/Achievements.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import Terminal from '../components/Terminal.astro';
---

<Base>
  <Header />
  <main id="main">
    <Hero />
    <Skills />
    <Projects />
    <Timeline />
    <Achievements />
    <Contact />
  </main>
  <Footer />
  <Terminal />

  <script>
    import { initThemeToggle } from '../scripts/theme.js';
    import { initScrollSpy } from '../scripts/nav.js';
    import { initSiteData } from '../scripts/siteData.js';
    import { initProjects } from '../scripts/projects.js';
    import { initContactForm } from '../scripts/contact.js';

    initThemeToggle();
    initScrollSpy();
    initSiteData();
    initProjects();
    initContactForm();

    // Terminal is lazy: module loads on first open (button or Ctrl+`)
    let terminal = null;
    async function openTerminal() {
      if (!terminal) {
        const { initTerminal } = await import('../scripts/terminal.js');
        terminal = initTerminal();
      }
      terminal?.open();
    }

    document.getElementById('terminal-open')?.addEventListener('click', openTerminal);
    document.addEventListener('keydown', (event) => {
      if (event.ctrlKey && event.key === '`') {
        event.preventDefault();
        openTerminal();
      }
    });
  </script>
</Base>
