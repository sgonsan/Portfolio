---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Skills from '../components/Skills.astro';
import Projects from '../components/Projects.astro';
import Timeline from '../components/Timeline.astro';
import Achievements from '../components/Achievements.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import Terminal from '../components/Terminal.astro';
import ProjectModal from '../components/ProjectModal.astro';
---

<Base>
  <Header />
  <main>
    <Hero />
    <Skills />
    <Projects />
    <Timeline />
    <Achievements />
    <Contact />
  </main>
  <Footer />
  <Terminal />
  <ProjectModal />

  <script>
    import { initSiteData } from '../scripts/siteData.js';
    import { initProjectsSection } from '../scripts/projects.js';
    import { initTimeline } from '../scripts/timeline.js';
    import { initContactForm } from '../scripts/contact.js';
    import { initTerminal } from '../scripts/terminal.js';
    import { initEffects } from '../scripts/effects.js';
    import { initProjectModal } from '../scripts/projectModal.js';

    initSiteData();
    initProjectsSection();
    initTimeline();
    initContactForm();
    initTerminal();
    initEffects();
    initProjectModal();
  </script>
</Base>
